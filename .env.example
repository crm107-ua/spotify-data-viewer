# =============================================================================
# Spotify Data Viewer — variables de entorno (opcionales)
# =============================================================================
# Copia este archivo a .env y rellena solo lo que necesites:
#   cp .env.example .env
#
# El dashboard funciona SIN este archivo. Solo necesitas tus JSON en data/.
# =============================================================================

# -----------------------------------------------------------------------------
# API de Spotify (OPCIONAL) — solo para la sección "Tendencia de géneros"
# -----------------------------------------------------------------------------
# Sin estas variables, el dashboard muestra todo excepto géneros.
# 1. Crea una app en https://developer.spotify.com/dashboard
# 2. Copia Client ID y Client Secret aquí
# 3. No hace falta configurar Redirect URI para esta funcionalidad

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
