# =============================================================================
# Spotify Data Viewer — optional environment variables
# =============================================================================
# Copy this file to .env and fill in only what you need:
#   cp .env.example .env
#
# The dashboard works WITHOUT this file. You only need your JSON files in data/.
# =============================================================================

# -----------------------------------------------------------------------------
# Spotify API (OPTIONAL) — only for the "Genre trends" section
# -----------------------------------------------------------------------------
# Without these variables, the dashboard shows everything except genres.
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. Copy Client ID and Client Secret here
# 3. No Redirect URI configuration needed for this feature

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
